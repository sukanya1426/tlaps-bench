-----------------MODULE PaxosProof_OtherMessage-------------------
EXTENDS TLAPS, PaxosTuple

-----------------------------------------------------------------------------

-----------------------------------------------------------

-----------------------------------------------------------

-----------------------------------------------------------------------------

THEOREM OtherMessage == \A m1, m2 \in msgs', a, b \in {"1a","2a","1b","2b"} :
               /\ m1[1] = a /\ m2[1] = b /\ a # b
               /\ msgs' = msgs \union {m2}
               => m1 \in msgs
PROOF
  <1> SUFFICES ASSUME NEW m1 \in msgs', NEW m2 \in msgs',
                      NEW a \in {"1a","2a","1b","2b"},
                      NEW b \in {"1a","2a","1b","2b"},
                      m1[1] = a, m2[1] = b, a # b,
                      msgs' = msgs \union {m2}
               PROVE m1 \in msgs
    OBVIOUS
  <1>1. m1 \in msgs \union {m2}
    OBVIOUS
  <1>2. CASE m1 = m2
    <2>1. a = b
      BY <1>2
    <2> QED
      BY <2>1
  <1>3. CASE m1 \in msgs
    BY <1>3
  <1> QED
    BY <1>1, <1>2, <1>3

------------------------------------------------------------
============================================================