----------------------------- MODULE VoteProof_GeneralNatInduction ------------------------------

EXTENDS Integers , FiniteSets, TLC, TLAPS

-----------------------------------------------------------------------------
CONSTANT Value,     
         Acceptor,  
         Quorum     

ASSUME QA == /\ \A Q \in Quorum : Q \subseteq Acceptor
             /\ \A Q1, Q2 \in Quorum : Q1 \cap Q2 # {}  
 
-----------------------------------------------------------------------------

-----------------------------------------------------------------------------

VARIABLES votes, maxBal

-----------------------------------------------------------------------------

-----------------------------------------------------------------------------

-----------------------------------------------------------------------------

AXIOM SimpleNatInduction == \A f : /\ f[0]
                                   /\ \A n \in Nat : f[n] => f[n+1]
                                   => \A n \in Nat : f[n]

THEOREM GeneralNatInduction == 
         \A f : /\ f[0]
                /\ \A n \in Nat : (\A j \in 0..n : f[j]) => f[n+1]
                => \A n \in Nat : f[n]
PROOF
<1> SUFFICES ASSUME NEW f,
                    f[0],
                    \A n \in Nat : (\A j \in 0..n : f[j]) => f[n+1]
             PROVE  \A n \in Nat : f[n]
  OBVIOUS
<1> DEFINE g == [n \in Nat |-> \A j \in 0..n : f[j]]
<1>1. g[0]
  <2> SUFFICES \A j \in 0..0 : f[j]
    BY DEF g
  <2> TAKE j \in 0..0
  <2>1. j = 0
    BY SMT
  <2>2. QED
    BY <2>1
<1>2. \A n \in Nat : g[n] => g[n+1]
  <2> TAKE n \in Nat
  <2> SUFFICES ASSUME g[n] PROVE g[n+1]
    OBVIOUS
  <2>1. \A j \in 0..n : f[j]
    BY DEF g
  <2>2. f[n+1]
    BY <2>1
  <2> SUFFICES \A j \in 0..(n+1) : f[j]
    BY DEF g
  <2> TAKE j \in 0..(n+1)
  <2>3. j \in 0..n \/ j = n+1
    BY SMT
  <2>4. QED
    BY <2>1, <2>2, <2>3
<1>3. \A n \in Nat : g[n]
  <2>1. (/\ g[0]
         /\ \A n \in Nat : g[n] => g[n+1]) => (\A n \in Nat : g[n])
    BY SimpleNatInduction
  <2>2. QED
    BY <1>1, <1>2, <2>1
<1>4. QED
  <2> TAKE n \in Nat
  <2>1. \A j \in 0..n : f[j]
    BY <1>3 DEF g
  <2>2. n \in 0..n
    BY SMT
  <2>3. QED
    BY <2>1, <2>2
-----------------------------------------------------------------------------

-----------------------------------------------------------------------------

-----------------------------------------------------------------------------

-----------------------------------------------------------------------------

-----------------------------------------------------------------------------

ASSUME AcceptorNonempty == Acceptor # {}

-----------------------------------------------------------------------------

-----------------------------------------------------------------------------

-----------------------------------------------------------------------------

ASSUME AcceptorFinite == IsFiniteSet(Acceptor)

ASSUME ValueNonempty == Value # {}
-----------------------------------------------------------------------------

AXIOM SubsetOfFiniteSetFinite == 
        \A S, T : IsFiniteSet(T) /\ (S \subseteq T) => IsFiniteSet(S)

AXIOM FiniteSetHasMax == 
        \A S \in SUBSET Int :
          IsFiniteSet(S) /\ (S # {}) => \E max \in S : \A x \in S : max >= x

AXIOM IntervalFinite == \A i, j \in Int : IsFiniteSet(i..j)
-----------------------------------------------------------------------------

