-------------------------- MODULE Allocator_InitMutex -----------------------------

CONSTANTS
  Client,     
  Resource    

VARIABLES
  unsat,       
  alloc        

-------------------------------------------------------------------------

Init ==
  /\ unsat = [c \in Client |-> {}]
  /\ alloc = [c \in Client |-> {}]

-------------------------------------------------------------------------

-------------------------------------------------------------------------

Mutex ==
  \A c1,c2 \in Client : \A r \in Resource :
     r \in alloc[c1] \cap alloc[c2] => c1 = c2

-------------------------------------------------------------------------

-------------------------------------------------------------------------

-------------------------------------------------------------------------

-------------------------------------------------------------------------

THEOREM InitMutex == Init => Mutex
PROOF
  <1> SUFFICES ASSUME Init,
                      NEW c1 \in Client, NEW c2 \in Client, NEW r \in Resource,
                      r \in alloc[c1] \cap alloc[c2]
               PROVE  c1 = c2
    BY DEF Mutex
  <1>1. alloc = [c \in Client |-> {}]
    BY DEF Init
  <1>2. alloc[c1] = {}
    BY <1>1
  <1>3. r \in alloc[c1]
    OBVIOUS
  <1> QED
    BY <1>2, <1>3

=========================================================================
